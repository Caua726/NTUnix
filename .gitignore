# NOTA: o Git nao suporta comentario no fim da linha. Um "padrao/  # texto"
# vira o padrao literal inteiro e nao casa com nada. Comentario so em linha
# propria, como estas.

# === Artefatos de build ===
out/
build/work/
musl-nt/build/
*.o
*.a
*.exe
*.obj
*.lib
*.dll
*.pdb

# fontes externas baixadas pelo `make deps` (musl, busybox) + a ISO do Windows
build/deps/

# === Imagens geradas / VM ===
*.iso
*.img
*.qcow2
*.vhd
*.vhdx
build/vm/

# === Logs de runtime / diagnostico ===
*.log
core
*.core
*.stackdump

# === Configs locais de ferramentas (nao compartilhadas) ===
.claude/settings.local.json
.codex/
.agents/
compile_commands.json
.cache/

# === Editor / SO ===
*.swp
*.swo
*~
*.orig
*.rej
.DS_Store
Thumbs.db
.idea/
.vscode/

# analise de imagem: dumps grandes e scripts descartaveis (build/mkprofile.py e
# build/dumpwim.py sao codigo de verdade e ficam rastreados)
build/analysis/
__pycache__/
*.pyc

# cache da extracao da ISO fonte (varios GB, regeneravel)
build/cache/
