#!/usr/bin/env bash
# Apply a BusyBox Kconfig miniconfig on top of an all-disabled baseline.
set -euo pipefail

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
    echo "usage: configure-busybox BUSYBOX_SOURCE [MINICONFIG]" >&2
    exit 2
fi

source_dir=$(cd "$1" && pwd)
root=$(cd "$(dirname "$0")/.." && pwd)
miniconfig=${2:-"$root/test/busybox-coreutils.config"}

make -s -C "$source_dir" allnoconfig >/dev/null

while IFS= read -r setting; do
    case "$setting" in
        CONFIG_*=*)
            symbol=${setting%%=*}
            escaped=$(printf '%s' "$setting" | sed 's/[&|]/\\&/g')
            if grep -q "^# $symbol is not set$" "$source_dir/.config"; then
                sed -i "s|^# $symbol is not set$|$escaped|" "$source_dir/.config"
            elif grep -q "^$symbol=" "$source_dir/.config"; then
                sed -i "s|^$symbol=.*$|$escaped|" "$source_dir/.config"
            else
                printf '%s\n' "$setting" >> "$source_dir/.config"
            fi
            ;;
    esac
done < "$miniconfig"

# Resolve dependencies and generated selections.  The allnoconfig baseline
# already contains every symbol, so oldconfig is non-interactive here.
make -s -C "$source_dir" oldconfig </dev/null >/dev/null

# NTUnix: patches no ash para o modelo de processo do NT (ver patches/).
#
# O fork() da NTUnix e' RtlCloneUserProcess (clone parcial) e o CreateProcessW
# CRASHA dentro do clone. O patch faz duas coisas:
#  (1) roda TODO applet in-process (nao so os NOEXEC) -- o exec no clone morre;
#  (2) roda programa externo real via posix_spawn (sem fork), no shell principal,
#      para rodar binarios Unix-para-NTUnix e apps Windows.
#
# Aplica de forma idempotente (so se ainda nao aplicado).
if ! grep -q 'spawn_external' "$source_dir/shell/ash.c"; then
    patch -p1 -d "$source_dir" < "$root/patches/busybox-ntunix-ash.patch"
fi
