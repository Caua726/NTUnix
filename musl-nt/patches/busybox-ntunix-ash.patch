+#if ENABLE_FEATURE_SH_STANDALONE
+/* NTUnix: roda um programa externo REAL via posix_spawn (sem fork). O fork da
+ * NTUnix e' RtlCloneUserProcess e o CreateProcessW crasha dentro do clone, entao
+ * fork+exec de binario externo nao funciona; posix_spawn faz o CreateProcessW no
+ * processo pai. As redirecoes ja estao aplicadas nos fds correntes (redirectsafe,
+ * herdadas pelo filho) e listvars da o env com as variaveis temporarias. Roda
+ * tanto app Unix-buildado-para-NTUnix quanto app Windows (ambos sao PE). Espelha
+ * a resolucao de path do shellexec. Devolve o exit code (0-255), ou -1 se o
+ * programa nao foi encontrado (o chamador cai no caminho de erro normal). */
+static int spawn_external(char **argv, const char *path, int idx)
+{
+	char **envp = listvars(VEXPORT, VUNSET, /*strlist:*/ NULL, /*end:*/ NULL);
+	char *prog = argv[0];
+	pid_t pid = -1;
+	int rc = ENOENT;
+	int wstatus = 0;
+	int direct = (strchr(prog, '/') != NULL)
+	          || (strchr(prog, '\\') != NULL)
+	          || (prog[0] && prog[1] == ':');   /* caminho Windows C:\... */
+
+	if (direct) {
+		rc = posix_spawn(&pid, prog, NULL, NULL, argv, envp);
+	} else {
+		struct stackmark smark;
+		setstackmark(&smark);
+		while (padvance(&path, prog) >= 0) {
+			char *cmdname = stackblock();
+			if (--idx < 0 && pathopt == NULL) {
+				rc = posix_spawn(&pid, cmdname, NULL, NULL, argv, envp);
+				if (rc == 0)
+					break;
+				if (rc != ENOENT && rc != ENOTDIR)
+					break;
+			}
+		}
+		popstackmark(&smark);
+	}
+
+	if (rc != 0)
+		return -1;   /* nao encontrado / erro -> caminho de erro normal */
+
+	while (waitpid(pid, &wstatus, 0) < 0 && errno == EINTR)
+		continue;
+	if (WIFSIGNALED(wstatus))
+		return 128 + WTERMSIG(wstatus);
+	return WEXITSTATUS(wstatus);
+}
+#endif
